# ─────────────────────────────────────────────────────────────────
# Large data files (>100MB, cannot push to GitHub)
# Users should download these from original sources.
# See data/DATA_SOURCES.md for download instructions.
# ─────────────────────────────────────────────────────────────────

# CPS ASEC microdata (Census Bureau, public domain, ~1.4GB total)
data/cps-asec/csv/asecpub*.zip
data/cps-asec/csv/2024/pppub24.csv
data/cps-asec/fixed-width/*.dat.gz

# ATUS microdata (BLS, public domain, ~31MB zipped)
data/atus/*.dat
data/atus/atus*-0324.zip

# ABS microdata (Census Bureau, public domain, ~55MB zipped)
data/abs/*.dat
data/abs/*.zip

# Penn World Table (downloadable from www.rug.nl/ggdc/productivity/pwt/)
data/pwt/

# macOS archive junk
**/__MACOSX/

# O*NET extracted database (keep the zip, exclude extracted ~90MB)
data/onet/db_29_1_text/
